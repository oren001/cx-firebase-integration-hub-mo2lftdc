# Firebase Integration Hub - Environment Variables Example
# Copy this file to .env or .dev.vars for local development
# Note: The Firebase config is currently hardcoded in firebase-config.js
# This file demonstrates the pattern for future projects that need environment-based configuration

# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General
FIREBASE_API_KEY=your-api-key-here
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=123456789012
FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Rate Limiting Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# Optional: Admin Configuration (for future admin-only endpoints)
ADMIN_SECRET_KEY=your-admin-secret-key-here

# Cloudflare Worker Configuration
# These are set in wrangler.toml but can be overridden here for local dev
# WORKER_ENV=development
# LOG_LEVEL=debug